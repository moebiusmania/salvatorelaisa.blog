{
	"private": true,
	"type": "module",
	"scripts": {
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "biome format --write .",
		"build": "nuxt build",
		"predev": "npm run format",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"test": "vitest",
		"test:update": "vitest -u",
		"test:coverage": "vitest run --coverage",
		"new:post": "deno run --allow-write scripts/post.ts",
		"new:device": "deno run --allow-write scripts/device.ts",
		"stats": "deno run --allow-read scripts/stats.ts",
		"drafts": "deno run --allow-read scripts/drafts.ts",
		"convert:webp": "deno run --allow-read --allow-write scripts/images-converter.ts",
		"todo:init": "deno run --allow-read --allow-write scripts/todo.ts init",
		"todo:list": "deno run --allow-read scripts/todo.ts list",
		"todo:add": "deno run --allow-read --allow-write scripts/todo.ts add",
		"todo:remove": "deno run --allow-read --allow-write scripts/todo.ts remove",
		"todo:done": "deno run --allow-read --allow-write scripts/todo.ts done"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@nuxt/content": "3.13.0",
		"@nuxt/fonts": "0.14.0",
		"@nuxt/image": "2.0.0",
		"@nuxt/test-utils": "4.0.3",
		"@nuxtjs/sitemap": "8.0.15",
		"@vue/test-utils": "2.4.10",
		"better-sqlite3": "12.9.0",
		"happy-dom": "20.9.0",
		"nuxt": "4.4.4",
		"oxlint": "1.63.0",
		"vitest": "4.1.5"
	}
}
